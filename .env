# JellyTrack public .env example
# Replace every value marked CHANGE_ME before production.

# Core services
DATABASE_URL="postgresql://JellyTrack:JellyTrack_password@postgres:5432/JellyTrack?schema=public"
REDIS_URL="redis://redis:6379"

# Jellyfin source
JELLYFIN_URL="http://jellyfin:8096"
JELLYFIN_API_KEY="CHANGE_ME_JELLYFIN_API_KEY"

# App mode and server identity
JELLYTRACK_MODE="single"
JELLYFIN_SERVER_ID="master"
JELLYFIN_SERVER_NAME="Master Jellyfin"

# Security
ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"
NEXTAUTH_SECRET="CHANGE_ME_NEXTAUTH_SECRET"
NEXTAUTH_URL="http://localhost:3000"
JELLYFIN_WEBHOOK_SECRET="CHANGE_ME_WEBHOOK_SECRET"

# Runtime
PORT="3000"
APP_PORT="3000"
BACKUP_DIR="/data/backups"

# Optional runtime toggles
PRISMA_USE_STUB="0"
