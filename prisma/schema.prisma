generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Server {
  id                String            @id @default(uuid())
  jellyfinServerId  String            @unique
  name              String
  url               String
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  users             User[]
  media             Media[]
  playbackHistory   PlaybackHistory[]
  telemetryEvents   TelemetryEvent[]
  activeStreams     ActiveStream[]
}

model User {
  id              String            @id @default(uuid())
  serverId        String
  jellyfinUserId  String
  username        String
  isActive        Boolean           @default(true)
  lastActive      DateTime?         // Dernière activité réelle (via heartbeat ou playback)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  server          Server            @relation(fields: [serverId], references: [id], onDelete: Cascade)
  playbackHistory PlaybackHistory[]
  activeStreams   ActiveStream[]

  @@unique([jellyfinUserId, serverId])
  @@index([serverId])
}

model Media {
  id              String            @id @default(uuid())
  serverId        String
  jellyfinMediaId String
  title           String
  type            String            // e.g., "Movie", "Episode", "Track"
  collectionType  String?           // e.g., "movies", "tvshows"
  libraryName     String?           // Actual Jellyfin library folder name (e.g., "film-1", "Séries TV")
  genres          String[]          // Tableau des genres (via sync)
  resolution      String?           // Ex: "4K", "1080p", "SD" (via sync)
  durationMs      BigInt?           // Durée totale du média
  size            BigInt?           // Taille du fichier en octets
  directors       String[]          @default([])
  actors          String[]          @default([])
  studios         String[]          @default([])
  parentId        String?           // Jellyfin ParentId (AlbumId, SeasonId, etc.) for image fallback
  artist          String?           // AlbumArtist (for Audio/MusicAlbum items)
  dateAdded       DateTime?         // Jellyfin DateCreated (real date added to library)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  server          Server            @relation(fields: [serverId], references: [id], onDelete: Cascade)
  playbackHistory PlaybackHistory[]
  activeStreams   ActiveStream[]

  @@unique([jellyfinMediaId, serverId])
  @@index([serverId])
  @@index([type])
  @@index([collectionType])
  @@index([jellyfinMediaId])
}

model PlaybackHistory {
  id              String    @id @default(uuid())
  serverId        String
  userId          String?
  mediaId         String
  
  // Streaming Info
  playMethod      String    // e.g., "DirectPlay", "Transcode", "DirectStream"
  clientName      String?   // e.g., "Jellyfin Web", "Android TV"
  deviceName      String?   // e.g., "Chrome", "Nvidia Shield"
  
  // GeoIP / Network Info
  ipAddress       String?
  country         String?
  city            String?
  
  // Stats
  durationWatched Int       @default(0) // en secondes
  startedAt       DateTime  @default(now())
  endedAt         DateTime? // Rempli lorsque la session s'arrête
  
  // Telemetry (Audio & Subtitles)
  audioLanguage    String?   // ex: "fre", "eng"
  audioCodec       String?   // ex: "aac", "ac3"
  subtitleLanguage String?   // ex: "fre", "eng"
  subtitleCodec    String?   // ex: "subrip", "ass"
  
  // Advanced Telemetry
  bitrate          Int?      // Bitrate in kbps (persisted from ActiveStream)
  pauseCount       Int       @default(0) // Number of times playback was paused
  audioChanges     Int       @default(0) // Number of audio track switches
  subtitleChanges  Int       @default(0) // Number of subtitle track switches
  
  server          Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media           Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  telemetryEvents TelemetryEvent[]

  @@index([serverId])
  @@index([userId])
  @@index([mediaId])
  @@index([startedAt])
  @@index([serverId, startedAt])
  @@index([userId, startedAt])
  @@index([serverId, userId, startedAt])
  @@index([mediaId, startedAt])
  @@index([serverId, mediaId, startedAt])
  @@index([clientName])
  @@index([playMethod])
}

model TelemetryEvent {
  id          String   @id @default(uuid())
  serverId    String
  playbackId  String
  eventType   String   // "pause", "audio_change", "subtitle_change", "stop"
  positionMs  BigInt   // Position within the media in milliseconds
  metadata    String?  // Optional JSON (e.g., new language, codec info)
  createdAt   DateTime @default(now())

  server      Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  playback    PlaybackHistory @relation(fields: [playbackId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([playbackId])
  @@index([eventType])
  @@index([serverId, eventType])
  @@index([playbackId, eventType])
}

model ActiveStream {
  id              String   @id @default(uuid())
  serverId        String
  sessionId       String   // Jellyfin Session ID
  userId          String
  mediaId         String
  
  // Streaming Info
  playMethod      String   // "DirectPlay", "Transcode"
  clientName      String?
  deviceName      String?
  ipAddress       String?
  country         String?
  city            String?
  
  // Transcoding Metrics
  videoCodec      String?
  audioCodec      String?
  transcodeFps    Float?
  bitrate         Int?
  
  // Telemetry (Audio & Subtitles)
  audioLanguage    String?
  subtitleLanguage String?
  subtitleCodec    String?
  
  // Tick updates
  positionTicks   BigInt?   // Position actuelle de lecture
  startedAt       DateTime @default(now())
  lastPingAt      DateTime @updatedAt // Dernière mise à jour (via webhook)
  
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media           Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([sessionId, serverId])
  @@index([serverId])
  @@index([lastPingAt])
  @@index([serverId, lastPingAt])
}

model GlobalSettings {
  id                    String   @id @default("global") // Singleton pattern pour les settings
  discordWebhookUrl     String?
  discordAlertCondition String   @default("ALL") // Filtre d'envoi ('ALL', 'TRANSCODE_ONLY', 'NEW_IP_ONLY')
  discordAlertsEnabled  Boolean  @default(false)
  maxConcurrentTranscodes Int      @default(0)     // 0 = désactivé. Alerte si dépassé.
  excludedLibraries     String[] @default([]) // Filtre les types de collection (ex: Photo, HomeVideos)
  syncCronHour          Int      @default(3)     // Hour (0-23) for daily full sync
  syncCronMinute        Int      @default(0)     // Minute (0-59) for daily full sync
  backupCronHour        Int      @default(3)     // Hour (0-23) for daily auto-backup
  backupCronMinute      Int      @default(30)    // Minute (0-59) for daily auto-backup
  defaultLocale         String   @default("fr")  // Default language for new users (fr, en)
  timeFormat            String   @default("24h") // Time display format: "12h" or "24h"
  wrappedVisible        Boolean  @default(true)  // Whether the Wrapped feature is visible to users
  wrappedPeriodEnabled  Boolean  @default(true)
  wrappedStartMonth     Int      @default(12)    // Month (1-12) when current year Wrapped becomes available
  wrappedStartDay       Int      @default(1)     // Day (1-31) when current year Wrapped becomes available
  wrappedEndMonth       Int      @default(1)     // Month (1-12) when current year Wrapped stops being available
  wrappedEndDay         Int      @default(31)    // Day (1-31) when current year Wrapped stops being available
  // Plugin connection system
  pluginApiKey          String?  // API key for Jellyfin plugin authentication
  pluginLastSeen        DateTime? // Last heartbeat from the plugin
  pluginVersion         String?  // Plugin version reported via heartbeat
  pluginServerName      String?  // Jellyfin server name reported via heartbeat
  resolutionThresholds  Json?    // Configurable boundaries for resolution detection (minWidth, minHeight, etc.)
  updatedAt             DateTime @updatedAt
}

model SystemHealthState {
  id        String              @id @default("global")
  monitor   Json
  sync      Json
  backup    Json
  updatedAt DateTime            @updatedAt
  events    SystemHealthEvent[]
}

model SystemHealthEvent {
  id        String            @id @default(uuid())
  stateId   String            @default("global")
  source    String
  kind      String
  message   String
  details   Json?
  createdAt DateTime          @default(now())
  state     SystemHealthState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([source, createdAt])
  @@index([kind, createdAt])
}

model DailyStats {
  id            String   @id @default(uuid())
  date          DateTime @db.Date
  userId        String?
  libraryName   String?
  mediaType     String?       // "Movie", "Episode", "Audio", etc.
  totalPlays    Int      @default(0)
  totalDuration Int      @default(0)  // seconds
  directPlays   Int      @default(0)
  transcodes    Int      @default(0)
  uniqueMedia   Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([date, userId, libraryName, mediaType])
  @@index([date])
  @@index([userId])
}

